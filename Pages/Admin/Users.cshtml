@page
@model IDFK.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users Panel";
}

<div class="container mt-5 text-light">
    @* הוספתי text-light כדי שיתאים לעיצוב הכהה שלך *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Managing users in the system</h2>
        @* בדיקה בטוחה לפני שמציגים כמות *@
        <span class="badge bg-primary">Total registered: @(Model.UsersList?.Count ?? 0)</span>
    </div>

    <div class="card shadow-sm bg-dark border-secondary">
        <table class="table table-hover mb-0 table-dark">
            <thead class="table-secondary text-dark">
                <tr>
                    <th>Img</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th class="text-center">Functions</th>
                </tr>
            </thead>
            <tbody>
                @* בדיקה: האם הרשימה קיימת ויש בה משתמשים? *@
                @if (Model.UsersList != null && Model.UsersList.Any())
                {
                    @foreach (var user in Model.UsersList)
                    {
                        <tr>
                            <td class="align-middle">
                                <img src="@(user.ProfilePicturePath ?? "/images/default-profile.png")"
                                     class="rounded-circle" style="width:40px; height:40px; object-fit:cover;" />
                            </td>
                            <td class="align-middle">@user.Username</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="text-center align-middle">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id"
                                      onsubmit="return confirm('Are you sure you want to delete @user.Username?');">
                                    <button class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4">No users found in the system.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
