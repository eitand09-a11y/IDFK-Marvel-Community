@page
@model IndexModel
@{
    ViewData["Title"] = "קהילת מארוול - דף הבית";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-danger">MARVEL UNIVERSE</h1>
    <p class="lead">Welcome to the official Marvel movie fan community.</p>
</div>

<div class="container">
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var movie in Model.MoviesList)
        {
            <div class="col">
                <div class="card h-100 marvel-card shadow border-0">
                    <div class="card-img-wrapper">
                        <img src="@(movie.PosterPath ?? "https://via.placeholder.com")" class="card-img-top" alt="@movie.Title">
                        <div class="year-badge">@movie.ReleaseYear</div>
                    </div>

                    <div class="card-body text-center">
                        <h5 class="card-title fw-bold">@movie.Title</h5>
                        <p class="card-text small">@movie.Description</p>
                    </div>

                    <div class="card-footer border-0 pb-3 px-3">
                        <a asp-page="/MovieDetails" asp-route-id="@movie.Id" class="btn btn-marvel w-100">
                            WATCH TRAILER & CHAT
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (Model.MoviesList.Count == 0)
{
    <div class="alert alert-info text-center mt-5">
        No movies have been added to the system yet. Admin, it's time to work!
    </div>
}
