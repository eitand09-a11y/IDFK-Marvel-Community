@page
@model IDFK.Pages.ProfileModel
@{
    ViewData["Title"] = "Personal Profile";
}

<div class="container mt-5">
    <div class="card shadow-sm" style="max-width: 500px; margin: auto;">
        <div class="card-header bg-primary text-white text-center">
            <h3>My Profile</h3>
        </div>
        <div class="card-body text-center">
            <!-- הצגת תמונת פרופיל או תמונת ברירת מחדל -->
            <img src="@(Model.CurrentUser?.ProfilePicturePath ?? "/images/default-avatar.png")"
                 class="rounded-circle mb-3" style="width: 150px; height: 150px; object-fit: cover; border: 2px solid #ddd;" />

            <h4 class="mb-1 text-white">@Model.CurrentUser?.Username</h4>
            <p class="text-muted">@Model.CurrentUser?.Email</p>

            <hr />

            <!-- טופס העלאת תמונה -->
            <form method="post" enctype="multipart/form-data" class="mt-3">
                <div class="mb-3">
                    <label class="form-label text-start d-block text-white">Update profile img:</label>
                    <input type="file" name="Upload" class="form-control" accept="image/*" />
                </div>
                <div class="mb-3">
                    <label class="form-label text-start d-block text-white">New password (Optional):</label>
                    <input type="password" asp-for="NewPassword" class="form-control" placeholder="Leave blank if you don't want to change." />
                </div>
                <button type="submit" class="btn btn-success w-100">Save changes</button>
            </form>
        </div>
    </div>
</div>
