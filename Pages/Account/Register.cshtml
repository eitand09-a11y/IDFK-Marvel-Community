@page
@model IDFK.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4 fw-bold">Create Account</h2>
                    <hr />

                    <form method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="NewUser.Username" class="form-control" placeholder="Username" />
                            <label asp-for="NewUser.Username">Username</label>
                            <span asp-validation-for="NewUser.Username" class="text-danger"></span> @* כאן תופיע הודעת השגיאה *@
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="NewUser.Email" class="form-control" type="email" />
                            <label asp-for="NewUser.Email">Email address</label>
                            <span asp-validation-for="NewUser.Email" class="text-danger"></span> @* כאן תופיע הודעת השגיאה *@
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="NewUser.Password" class="form-control" type="password" placeholder="Password" />
                            <label asp-for="NewUser.Password">Password</label>
                            <span asp-validation-for="NewUser.Password" class="text-danger"></span> @* כאן תופיע הודעת השגיאה *@
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">Register Now</button>
                    </form>

                    <div class="mt-3 text-center">
                        <p class="text-muted">Already have an account? <a asp-page="./Login" class="text-primary text-decoration-none">Login here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
