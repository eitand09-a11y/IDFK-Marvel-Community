@page
@model IDFK.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4 fw-bold">Login</h2>
                    <hr />

                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="alert alert-danger text-center">@Model.Message</div>
                    }

                    <form method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Email">Email address</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Password" class="form-control" type="password" placeholder="Password" />
                            <label asp-for="Password">Password</label>
                        </div>

                        <button type="submit" class="btn btn-success w-100 btn-lg shadow-sm">Sign In</button>
                    </form>

                    <div class="mt-3 text-center">
                        <p class="text-muted">New here? <a asp-page="./Register" class="text-success text-decoration-none">Create an account</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
