<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IDFK</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3 py-2" style="background-color: var(--marvel-card-bg);">
            <div class="container-fluid d-flex align-items-center">

                <!-- 1. צד שמאל: לוגו ותפריט -->
                <div class="d-flex align-items-center" style="flex: 1;">
                    <a class="navbar-brand fw-bold text-danger Oswald" asp-page="/Index" style="font-size: 1.5rem; letter-spacing: 1px;">IDFK</a>
                    <div class="navbar-collapse collapse d-sm-inline-flex">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link text-light opacity-75" asp-page="/Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light opacity-75" asp-page="/Privacy">Privacy</a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- 2. צד אמצע: סוויצ'ר איירון מן / קפטן (ממורכז תמיד) -->
                <div class="d-flex justify-content-center" style="flex: 1.5;">
                    <div class="theme-switcher-container">
                        <div class="theme-option ironman-side active" onclick="setTheme('ironman', event)">IRON MAN</div>
                        <div class="theme-option captain-side" onclick="setTheme('captain', event)">CAPTAIN AMERICA</div>
                    </div>
                </div>

                <!-- 3. צד ימין: SHIELD ופרטי משתמש -->
                <div class="d-flex align-items-center justify-content-end" style="flex: 1;">

                    <!-- כפתור ניטרלי -->
                    <button class="neutral-theme-btn me-3" id="btn-neutral" onclick="setNeutralTheme()">
                        S.H.I.E.L.D MODE
                    </button>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-3">
                                <div class="d-flex align-items-center text-decoration-none text-light">
                                    @* תמונת פרופיל מה-Claims או ברירת מחדל *@
                                    <img src="@(User.FindFirst("ProfilePicture")?.Value ?? "/images/default-profile.png")"
                                         class="rounded-circle me-2"
                                         style="width:32px; height:32px; object-fit:cover; border:1px solid var(--marvel-accent);" />
                                    <span class="fw-bold small">Hello, @User.Identity.Name!</span>
                                </div>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item me-2">
                                    <a class="nav-link text-danger fw-bold small p-1" asp-page="/Admin/Users">Admin</a>
                                </li>
                                <li class="nav-item me-2">
                                    <a class="nav-link text-danger fw-bold small p-1" asp-page="/Admin/AddMovie">Add Movie</a>
                                </li>
                            }

                            <li class="nav-item">
                                <form class="form-inline" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="btn btn-link text-muted p-0 small" style="text-decoration:none;">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light small" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm ms-2" asp-page="/Account/Register">Register</a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
        <script>
            (function () {
                const savedTheme = localStorage.getItem('selectedTheme') || 'ironman';
                document.documentElement.setAttribute('data-theme', savedTheme);
            })();
        </script>

    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2026 - IDFK - <a asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<script>
        function setTheme(themeName) {
        // 1. עדכון ה-HTML Attribute (בשביל ה-CSS)
        document.documentElement.setAttribute('data-theme', themeName);

        // 2. שמירה ב-LocalStorage (בשביל הריפרש)
        localStorage.setItem('selectedTheme', themeName);

        // 3. עדכון ויזואלי של הכפתורים (הוספת Class active)
        const ironmanBtn = document.querySelector('.ironman-side');
        const captainBtn = document.querySelector('.captain-side');
        const neutralBtn = document.getElementById('btn-neutral');

        // איפוס כולם
        ironmanBtn.classList.remove('active');
        captainBtn.classList.remove('active');
        neutralBtn.classList.remove('active');

        // הדלקת הנכון
        if (themeName === 'ironman') ironmanBtn.classList.add('active');
        if (themeName === 'captain') captainBtn.classList.add('active');
        if (themeName === 'neutral') neutralBtn.classList.add('active');
    }

    function setNeutralTheme() {
        setTheme('neutral');
    }

    // מה קורה כשהדף מסיים להיטען
    window.addEventListener('DOMContentLoaded', (event) => {
        const savedTheme = localStorage.getItem('selectedTheme') || 'ironman';
        setTheme(savedTheme); // מפעיל את העיצוב השמור ומסדר את הכפתורים
    });

</script>
