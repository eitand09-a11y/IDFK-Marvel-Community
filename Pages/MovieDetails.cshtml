@page "{id:int}"
@model IDFK.Pages.MovieDetailsModel
@{
    ViewData["Title"] = Model.Movie.Title;

    var videoId = "";
    if (!string.IsNullOrEmpty(Model.Movie.TrailerUrl))
    {
        // מחלץ את ה-ID של הסרט מיוטיוב
        var uri = new Uri(Model.Movie.TrailerUrl);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        videoId = query.ContainsKey("v") ? query["v"] : uri.Segments.Last();
    }
    var embedUrl = $"https://www.youtube.com{videoId}";
}

<div class="container mt-4">
    <div class="row">
        <!-- פוסטר ומידע -->
        <div class="col-md-4 text-center">
            <img src="@Model.Movie.PosterPath" class="img-fluid rounded shadow border border-danger" alt="@Model.Movie.Title" style="max-height: 500px;">
            <h2 class="mt-3 fw-bold">@Model.Movie.Title</h2>
            <span class="badge bg-danger mb-3">@Model.Movie.ReleaseYear</span>
            <p class="text-muted text-end">@Model.Movie.Description</p>
        </div>

        <!-- טריילר וצאט -->
        <div class="col-md-8">
            <div class="ratio ratio-16x9 shadow rounded overflow-hidden mb-4 border border-secondary bg-dark">
                <iframe width="100%" height="315"
                        src="@Model.Movie.TrailerUrl.Replace("watch?v=", "embed/")"
                        frameborder="0" allowfullscreen>
                </iframe>
            </div>

            <div class="card bg-light">
                <div class="card-header bg-dark text-white">
                    <i class="bi bi-chat-dots"></i> צאט קהילת @Model.Movie.Title
                </div>

                <div class="card-body" style="height: 300px; overflow-y: auto;" id="chatWindow">
                    <!-- טעינת הודעות ישנות מה-DB -->
                    @foreach (var msg in Model.ChatHistory)
                    {
                        <div class="p-2 mb-2 bg-white border-bottom shadow-sm rounded">
                            <strong class="text-danger">@msg.User:</strong> @msg.Message
                            <small class="text-muted d-block" style="font-size: 0.7em;">@msg.Timestamp.ToString("HH:mm")</small>
                        </div>
                    }
                </div>

                <!-- הגבלה למשתמשים מחוברים בלבד -->
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="card-footer">
                        <div class="input-group">
                            <input id="chatInput" type="text" class="form-control" placeholder="כתוב משהו למעריצים..." onkeypress="if(event.key === 'Enter') sendMessage()">
                            <button onclick="sendMessage()" class="btn btn-danger">Send</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card-footer text-center bg-warning-subtle">
                        <span>כדי להשתתף בצאט הקהילה, עליך <a asp-page="/Account/Login" class="fw-bold text-danger">להתחבר למערכת</a>.</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- קישור מקומי לקובץ שהרגע התקנו -->
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    <script>
        // הקוד של הצאט שכתבנו קודם
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveMessage", function (user, message, movieId, profilePic, messageId) {
            if (movieId === "@Model.Movie.Id") {
                var chatWin = document.getElementById("chatWindow");

                // בדיקה בטוחה של תפקיד האדמין
                var isAdmin = @(User.IsInRole("Admin") ? "true" : "false");

                var deleteBtn = "";
                if (isAdmin) {
                    deleteBtn = `<button onclick="deleteMsg(${messageId})" class="btn btn-sm text-danger p-0 ms-2" title="מחק">🗑️</button>`;
                }

                var msgElement = `
                    <div id="msg-${messageId}" class="d-flex mb-3 align-items-center">
                        <img src="${profilePic}" class="rounded-circle me-2" style="width:40px; height:40px; object-fit:cover;">
                        <div class="bg-light p-2 rounded shadow-sm border d-flex align-items-center">
                            <div>
                                <strong class="text-primary">${user}</strong>:
                                <span>${message}</span>
                            </div>
                            ${deleteBtn}
                        </div>
                    </div>`;

                chatWin.innerHTML += msgElement;
                chatWin.scrollTop = chatWin.scrollHeight;
            }
        });

        connection.start().then(function() {
            console.log("מחובר לצאט מקומית!");
        }).catch(function (err) {
            console.error(err.toString());
        });

        function sendMessage() {
            var user = "@(User.Identity.IsAuthenticated? User.Identity.Name : "אורח")";
            var message = document.getElementById("chatInput").value;
            var movieId = "@Model.Movie.Id";

            if (message.trim() !== "") {
                // כאן אנחנו קוראים לשרת ושולחים 3 פרמטרים
                connection.invoke("SendMessage", user, message, movieId)
                    .catch(function (err) {
                        return console.error(err.toString());
                    });
                document.getElementById("chatInput").value = "";
            }
        }

        // פונקציה שהאדמין קורא לה בלחיצה
        function deleteMsg(msgId) {
            if(confirm("למחוק את ההודעה?")) {
                connection.invoke("DeleteMessage", msgId).catch(err => console.error(err));
            }
        }

        // מאזין שמקבל הודעה מהשרת שהודעה נמחקה
        connection.on("MessageDeleted", function (msgId) {
            var element = document.getElementById("msg-" + msgId);
            if (element) {
                element.style.opacity = "0"; // אפקט היעלמות קטן
                setTimeout(() => element.remove(), 500);
            }
        });


    </script>
}
